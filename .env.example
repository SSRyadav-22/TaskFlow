# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=*

# ── Database ──────────────────────────────────────────────────────────────────
# Railway provides this automatically when you add a PostgreSQL plugin.
# Leave blank for local development (SQLite is used by default).
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (set in Railway for prod).
# Example: https://taskflow.vercel.app,https://www.taskflow.vercel.app
# Leave blank during local development (all origins allowed).
# CORS_ALLOWED_ORIGINS=https://your-vercel-app.vercel.app
